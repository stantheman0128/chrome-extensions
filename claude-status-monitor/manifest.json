{
  "manifest_version": 3,
  "name": "Claude Status Monitor",
  "version": "1.0",
  "description": "在 Claude.ai 頁面即時顯示 Claude 服務狀態，資料來源：status.claude.com",
  "permissions": ["alarms"],
  "host_permissions": ["https://status.claude.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
