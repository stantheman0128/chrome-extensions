{
  "manifest_version": 3,
  "name": "YouTube 絕對精確日期 (完美客製版)",
  "version": "8.0",
  "description": "精準顯示上傳日期至秒數。支援影片播放頁、首頁、推薦欄、訂閱、歷史、播放清單、Shorts 等所有有影片的頁面。",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
