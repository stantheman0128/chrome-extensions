{
  "manifest_version": 3,
  "name": "Colonist.io Stats Tracker",
  "version": "1.66.0",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "homepage_url": "https://github.com/stantheman0128/chrome-extensions",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Colonist.io Stats Tracker",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://colonist.io/*", "*://*.colonist.io/*"],
      "js": ["msgpack.js", "ws-inspector.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://colonist.io/*", "*://*.colonist.io/*"],
      "js": ["board.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
